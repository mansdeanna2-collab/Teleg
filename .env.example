# ============================================
# Telegram Admin Server - 环境变量配置
# ============================================
# 复制此文件为 .env 并修改为你的实际配置
# cp .env.example .env

# 服务器 IP 地址（必填，用于前端 App 连接后端）
SERVER_IP=YOUR_SERVER_IP_HERE

# 服务端口（默认 8080）
SERVER_PORT=8080

# ---- 数据库配置 ----
DB_USERNAME=sa
DB_PASSWORD=change_me_to_secure_password

# ---- JWT 认证配置 ----
# 至少 64 个字符的随机字符串
JWT_SECRET=ChangeThisToASecureRandomStringAtLeast64CharactersLongForProduction!!

# ---- 管理员账号 ----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_to_secure_password
ADMIN_EMAIL=admin@yourdomain.com

# ---- CORS 跨域配置 ----
# 多个域名用逗号分隔，部署时会自动添加服务器地址
CORS_ORIGINS=http://localhost:8080

# ---- Spring 配置 ----
SPRING_PROFILES_ACTIVE=production
